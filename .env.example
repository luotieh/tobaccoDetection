# Local profile: dev, demo, or real.
TOBACCO_PROFILE=dev

# Management app
MANAGEMENT_HOST=0.0.0.0
MANAGEMENT_PORT=8000
VISION_SERVICE_URL=http://127.0.0.1:9000
TEXT_SERVICE_URL=http://127.0.0.1:8010
AUDIO_SERVICE_URL=http://127.0.0.1:8020
# 高风险账户反馈爬虫端：审核确认违法后 POST {platform,id,risk_score}
# 仅需按部署环境修改 IP/端口；路径一般不用改
CRAWLER_RISK_API_BASE=http://10.20.30.58:5001
CRAWLER_RISK_API_PATH=/api/internal/users/risk-score
# 评论区用户判定高风险的分数阈值（含一级/二级评论）。评论比整帖门槛低，
# 售卖帖下的购买/交易/价格询问即应上报，默认 0.65（中风险及以上）
COMMENT_HIGH_RISK_THRESHOLD=0.65
# 单条内容识别阶段最多给多少条评论打分（结合帖子上下文，过大评论区会拖慢识别）
COMMENT_SCORE_MAX=100
# 自动化审核反馈：识别为高风险的内容自动把风险账户(发帖人+评论区高风险用户)反馈爬虫端，
# 无需人工确认。设为 false 则仅在人工审核确认后反馈
AUTO_FEEDBACK_ON_RECOGNIZE=true

# Vision service
HOST=0.0.0.0
PORT=9000
APP_ENV=dev
YOLO_WEIGHTS=models/best.pt
# 可选 basant-yolo26s / enos-yolo11m / tobacco-yolo11s（本地训练，烟盒/条盒）
YOLO_MODEL_ID=basant-yolo26s
YOLO_CONF=0.35
YOLO_IOU=0.45
# 全局默认推理尺寸；tobacco-yolo11s 会自动用 weights/args.yaml 中的 imgsz=1280 覆盖
YOLO_IMG_SIZE=960
# 图像真实识别：设为 false 并选 tobacco-yolo11s（YOLO_MODEL_ID=tobacco-yolo11s）
USE_MOCK_MODEL=true
ENABLE_OCR=true
OCR_ENGINE=rapidocr

# Management-side image detector model paths
SMOKING_DETECTOR_MODEL=basant-yolo26s
SMOKING_MODEL_PATH=models/best.pt
ENOS_SMOKING_MODEL_PATH=models/enos-smoking-detection-best.pt
TOBACCO_MODEL_PATH=weights/best.pt

# Text service
TEXT_HOST=0.0.0.0
TEXT_PORT=8010
TEXT_APP_ENV=dev
TEXT_USE_MOCK_MODEL=true
TEXT_SEMANTIC_ENGINE=mock
TEXT_MODEL_DIR=text_models/text-risk-model
TEXT_LLM_PROVIDER=local
TEXT_LLM_MODEL_DIR=text_models/qwen2.5-0.5b-instruct
TEXT_LLM_API_BASE_URL=
TEXT_LLM_API_KEY_ENV=TEXT_LLM_API_KEY
TEXT_LLM_API_MODEL=
TEXT_LLM_MAX_NEW_TOKENS=256
TEXT_LLM_TEMPERATURE=0.0
TEXT_LLM_TIMEOUT_SECONDS=10
# 批量推理(/infer/batch)并发线程数：评论区逐条 LLM 打分并发上限，过大易触发上游限流
TEXT_BATCH_MAX_WORKERS=8
TEXT_MAX_TEXT_LENGTH=512
TEXT_ENABLE_RULES=true
TEXT_ENABLE_MASKING=true

# Audio service
AUDIO_HOST=0.0.0.0
AUDIO_PORT=8020
ASR_ENGINE=mock
ALLOW_ASR_FALLBACK=true
ASR_LANGUAGE=zh
ASR_DEVICE=cpu
ASR_COMPUTE_TYPE=int8
WHISPER_MODEL_SIZE=tiny
USE_MOCK_TRANSCRIPT=false
MOCK_TRANSCRIPT=
MAX_MEDIA_SECONDS=300
MAX_FILE_SIZE_MB=200

# Profile notes:
# dev  - development mode; services start with safe defaults and mocks allowed.
# demo - deterministic demo mode; explicitly enables mock transcript and mock vision hit paths.
# real - real inference mode; disables model fallbacks and requires local YOLO / ASR readiness.
