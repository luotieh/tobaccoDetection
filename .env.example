APP_NAME=tobacco-vision-risk-service
APP_ENV=dev
HOST=0.0.0.0
PORT=8000

# YOLO
YOLO_WEIGHTS=models/best.pt
YOLO_MODEL_ID=basant-yolo26s
YOLO_CONF=0.35
YOLO_IOU=0.45
YOLO_IMG_SIZE=960
USE_MOCK_MODEL=true

# OCR
ENABLE_OCR=true
OCR_ENGINE=rapidocr

# Video
VIDEO_SAMPLE_FPS=1
MAX_VIDEO_SECONDS=180
MAX_EVIDENCE_FRAMES=10

# Storage
UPLOAD_DIR=storage/uploads
EVIDENCE_DIR=storage/evidence
RESULT_DIR=storage/results

# Risk threshold
RISK_HIGH=0.85
RISK_MEDIUM=0.70
RISK_LOW=0.50
